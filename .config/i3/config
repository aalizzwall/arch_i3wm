# 按 Print Screen 截取全螢幕，並存到 Pictures 資料夾
bindsym Print exec --no-startup-id scrot 'screenshot_%Y-%m-%d-%H%M%S.png' -e 'mv $f ~/Pictures/'

# 按 Shift + Print Screen 讓你用滑鼠框選特定區域截圖
bindsym $mod+Shift+s exec --no-startup-id scrot -s 'screenshot_%Y-%m-%d-%H%M%S.png' -e 'mv $f ~/Pictures/'

# resize window (you can also use the mouse for that)
mode "resize" {
  # These bindings trigger as soon as you enter the resize mode
  
  # Pressing left will shrink the window’s width.
  # Pressing right will grow the window’s width.
  # Pressing up will shrink the window’s height.
  # Pressing down will grow the window’s height.
    bindsym j resize shrink width 10 px or 10 ppt
    bindsym k resize grow height 10 px or 10 ppt
    bindsym l resize shrink height 10 px or 10 ppt
    bindsym semicolon resize grow width 10 px or 10 ppt
  
  # same bindings, but for the arrow keys
    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt
  
  # back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

bindsym $mod+r mode "resize"

#Mount
set $mode_mount All (a) Hangouts (m) Mount (u) unMount
mode "$mode_mount" {
  bindsym m exec --no-startup-id udisksctl mount -b /dev/sde1 , mode "default"
  bindsym u exec --no-startup-id udisksctl unmount -b /dev/sde1 , mode "default"
  bindsym a exec --no-startup-id i3-sensible-terminal -x 'sudo mount Product && sudo mount VMs && sudo mount workspace && sudo mount project' , mode "default"

  # back to normal: Enter or Escape
  bindsym Return mode "default"
  bindsym Escape mode "default"
}
bindsym $mod+m mode "$mode_mount"



exec --no-startup-id feh --bg-scale /usr/local/share/wallpaper/GOD.JPG
exec --no-startup-id fcitx-autostart
exec --no-startup-id xss-lock -- i3lock -n -c 000000 
exec --no-startup-id xbacklight -set 0%
# 開機自動啟動藍牙常駐程式
exec --no-startup-id blueman-applet

# 1. 賦予 cava 專屬視窗「浮動」與「無邊框」的特權
for_window [title="cava-widget"] floating enable
for_window [title="cava-widget"] border pixel 0

# 2. 設定一個快捷鍵 (例如 Win + C) 來召喚這個浮動視窗
#bindsym $mod+c exec --no-startup-id terminator -T "cava-widget" -x cava

# 呼叫 Rofi 計算機 (即打即算，按 Enter 複製結果)
bindsym $mod+c exec --no-startup-id rofi -show calc -modi calc -no-show-match -no-sort


# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
bar {
  status_command i3blocks
  tray_output primary
}
