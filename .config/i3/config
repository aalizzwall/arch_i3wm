# ==============================================================================
# 🐧 Pascal's Ultimate i3wm Configuration (MacBook Pro & m6s)
# ==============================================================================

# --- 1. 基本設定與變數 (Base Settings) ---
set $mod Mod4
set $Locker "xset dpms force off && i3lock -n -c 000000"

# 字體設定 (影響視窗標題與 Bar)
font pango:Noto Mono CJK TC 8

# 拖曳浮動視窗的快捷鍵 (按住 Win 鍵 + 滑鼠左鍵拖曳)
floating_modifier $mod

# --- 2. 視窗外觀與縫隙 (Gaps & Borders) ---
new_window pixel
gaps inner 10
gaps outer 5

# 隱藏原本肥厚醜陋的視窗標題列，只保留 2px 的細邊框
for_window [class="^.*"] border pixel 2

# 聰明模式：如果畫面上只有一個視窗，就自動取消縫隙把畫面填滿
smart_gaps on
smart_borders on

# --- 3. 開機自動啟動 (Autostart) ---
# ⚠️ 注意：中文輸入法 (fcitx5) 已在 ~/.xinitrc 中宣告啟動，此處不需重複啟動以免衝突
exec --no-startup-id xss-lock -- i3lock -n -c 000000 
exec --no-startup-id blueman-applet
exec --no-startup-id feh --bg-scale /usr/local/share/wallpaper/GOD.JPG

# QoL 現代化桌面套件 (通知中心、隨身碟自動掛載、視窗透明與特效)
exec --no-startup-id dunst
exec --no-startup-id picom -b


# --- 4. 系統與硬體控制快捷鍵 (Hardware Controls) ---
# 音量控制 (使用 PipeWire/wpctl 並即時通知 i3blocks 更新狀態)
bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 && wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 3%+ && pkill -RTMIN+10 i3blocks
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 && wpctl set-volume @DEFAULT_AUDIO_SINK@ 3%- && pkill -RTMIN+10 i3blocks
bindsym XF86AudioMute exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle && pkill -RTMIN+10 i3blocks

# 螢幕亮度控制 (全面改用 brightnessctl，解決 xbacklight 跨硬體失效問題)
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-

# 螢幕截圖 (全螢幕與區域框選)
bindsym Print exec --no-startup-id scrot 'screenshot_%Y-%m-%d-%H%M%S.png' -e 'mv $f ~/Pictures/'
bindsym $mod+Shift+s exec --no-startup-id scrot -s 'screenshot_%Y-%m-%d-%H%M%S.png' -e 'mv $f ~/Pictures/'

# --- 5. 應用程式快捷鍵 (Applications) ---
# 終端機
bindsym $mod+Return exec i3-sensible-terminal

# 殺死當前視窗
bindsym $mod+Shift+q kill

# Rofi 應用程式啟動器 (取代 dmenu)
bindsym $mod+d exec --no-startup-id rofi -show drun -show-icons -font "JetBrainsMono Nerd Font 12"

# Rofi 計算機 (即打即算，按 Enter 複製結果)
bindsym $mod+c exec --no-startup-id rofi -show calc -modi calc -no-show-match -no-sort

# --- 6. 視窗焦點與移動 (Focus & Move) ---
# 焦點切換 (Vim 鍵位 or 方向鍵)
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# 移動視窗
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# 排版切換
bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# 浮動與平鋪切換
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

# --- 7. 工作區切換與移動 (Workspaces) ---
bindsym $mod+1 workspace 1
bindsym $mod+2 workspace 2
bindsym $mod+3 workspace 3
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8
bindsym $mod+9 workspace 9
bindsym $mod+0 workspace 10

bindsym $mod+Shift+1 move container to workspace 1
bindsym $mod+Shift+2 move container to workspace 2
bindsym $mod+Shift+3 move container to workspace 3
bindsym $mod+Shift+4 move container to workspace 4
bindsym $mod+Shift+5 move container to workspace 5
bindsym $mod+Shift+6 move container to workspace 6
bindsym $mod+Shift+7 move container to workspace 7
bindsym $mod+Shift+8 move container to workspace 8
bindsym $mod+Shift+9 move container to workspace 9
bindsym $mod+Shift+0 move container to workspace 10

# --- 8. i3wm 系統控制 (Reload & Exit) ---
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -b 'Yes, exit i3' 'i3-msg exit'"

# --- 10. 自訂多層級模式 (Custom Modes) ---

# [系統電源模式]
set $mode_system System (l) lock, (e) logout, (s) suspend, (h) hibernate, (r) reboot, (Shift+s) shutdown
mode "$mode_system" {
  bindsym l exec --no-startup-id $Locker, mode "default"
  bindsym e exec --no-startup-id i3-msg exit, mode "default"
  bindsym s exec --no-startup-id systemctl suspend, mode "default"
  bindsym h exec --no-startup-id systemctl hybrid-sleep, mode "default"
  bindsym r exec --no-startup-id systemctl reboot, mode "default"
  bindsym Shift+s exec --no-startup-id poweroff -p, mode "default"  
  bindsym Return mode "default"
  bindsym Escape mode "default"
}
bindsym $mod+Home mode "$mode_system"

# [外接螢幕模式]
set $External $(xrandr | grep " connected" | sed -e "s/\([A-Z0-9]\+\) connected.*/\1/" |grep -v DP-0)
set $mode_display Ext Screen (l|r) HDMI ON, (h) DP ON, (x) HDMI OFF, (y) DP OFF
mode "$mode_display" {
  bindsym r exec --no-startup-id xrandr --output $External --auto --right-of DP-0, mode "default"
  bindsym l exec --no-startup-id xrandr --output $External --auto --left-of DP-0, mode "default"
  bindsym x exec --no-startup-id xrandr --output $External --auto --off, mode "default"
  bindsym Return mode "default"
  bindsym Escape mode "default"
}
bindsym $mod+x mode "$mode_display"

# [視窗縮放模式]
mode "resize" {
  bindsym j resize shrink width 10 px or 10 ppt
  bindsym k resize grow height 10 px or 10 ppt
  bindsym l resize shrink height 10 px or 10 ppt
  bindsym semicolon resize grow width 10 px or 10 ppt
  bindsym Left resize shrink width 10 px or 10 ppt
  bindsym Down resize grow height 10 px or 10 ppt
  bindsym Up resize shrink height 10 px or 10 ppt
  bindsym Right resize grow width 10 px or 10 ppt
  bindsym Return mode "default"
  bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# --- 11. 狀態列 (Status Bar) ---
bar {
  status_command i3blocks
  tray_output primary
}
